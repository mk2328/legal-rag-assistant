# Secret keys - kabhi bhi GitHub pe nahi jaana chahiye
.env

# Virtual environment - 500MB+ ka folder
venv/
.venv/
env/

# User uploaded documents aur indexes - sirf content ignore karo
documents/*
!documents/.gitkeep

# FAISS index files - har machine pe rebuild honti hain
*.bin
*.pkl

# Python cache files - automatically banta hai
__pycache__/
*.pyc
*.pyo
*.pyd

# VS Code settings
.vscode/

# OS generated files
.DS_Store
Thumbs.db

# Test PDFs
*.pdf

# Google OAuth credentials
google_credentials.json